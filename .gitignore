# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment files — NEVER commit real secrets
.env
.env.local
.env.production.local
.env.development.local
.env.test.local

# .env.example files are safe to commit (they contain no real secrets)
!.env.example
!server/.env.example

# Server exclusions
server/node_modules
server/dist
server/.env
server/.env.local
server/prisma/dev.db
server/prisma/dev.db-journal
server/prisma/migrations/

# Prisma — keep migrations in git for PostgreSQL deployments
!server/prisma/migrations/
